\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  Pipeline overview of the proposed method. We first build a stable geometric scaffold from fixed-pose COLMAP sparse support with weak geometric priors, then perform no-densify reliability-aware geometry refinement, and finally freeze the main geometry for YCbCr-decoupled appearance refinement with calibrated proxy supervision.}}{4}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline_overview}{{2}{4}{Pipeline overview of the proposed method. We first build a stable geometric scaffold from fixed-pose COLMAP sparse support with weak geometric priors, then perform no-densify reliability-aware geometry refinement, and finally freeze the main geometry for YCbCr-decoupled appearance refinement with calibrated proxy supervision}{figure.caption.1}{}}
\newlabel{fig:pipeline_overview@cref}{{[figure][2][]2}{[1][3][]4}{}{}{}}
